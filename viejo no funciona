<div id="tweaks-panel">
  <h4>Tweaks</h4>
  <div class="tweak-row">
    <label>Color blob / acento</label>
    <input type="color" id="tw-blob" value="#f97316">
  </div>
  <div class="tweak-row">
    <label>Fondo</label>
    <select id="tw-bg">
      <option value="#ece5d8">Crema cálido (actual)</option>
      <option value="#f0ede8">Marfil suave</option>
      <option value="#e8e4f0">Lavanda pálido</option>
      <option value="#0c0c0e">Oscuro profundo</option>
    </select>
  </div>
</div>

<script>
  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  // Gallery scroll
  function scrollGallery(btn, dir) {
    const gallery = btn.parentElement.querySelector('.tl-gallery');
    gallery.scrollBy({ left: dir * 300, behavior: 'smooth' });
  }

  // Lightbox
  function openLightbox(src) {
    document.getElementById('lightbox-img').src = src;
    document.getElementById('lightbox').classList.add('open');
  }
  function closeLightbox() { document.getElementById('lightbox').classList.remove('open'); }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  // Tweaks
  const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{"blob":"#f97316","bg":"#ece5d8"}/*EDITMODE-END*/;
  let tweaks = { ...TWEAK_DEFAULTS };

  function hexToRgb(h){const n=parseInt(h.slice(1),16);return[(n>>16)&255,(n>>8)&255,n&255];}
  function rgbToHsl(r,g,b){r/=255;g/=255;b/=255;const mx=Math.max(r,g,b),mn=Math.min(r,g,b);let h,s,l=(mx+mn)/2;if(mx===mn){h=s=0;}else{const d=mx-mn;s=l>.5?d/(2-mx-mn):d/(mx+mn);switch(mx){case r:h=((g-b)/d+(g<b?6:0))/6;break;case g:h=((b-r)/d+2)/6;break;case b:h=((r-g)/d+4)/6;break;}}return[h*360,s*100,l*100];}
  function hslToHex(h,s,l){s/=100;l/=100;const a=s*Math.min(l,1-l);const f=n=>{const k=(n+h/30)%12;const c=l-a*Math.max(-1,Math.min(k-3,9-k,1));return Math.round(255*c).toString(16).padStart(2,'0')};return`#${f(0)}${f(8)}${f(4)}`;}
  function shiftHue(hex,deg){const[r,g,b]=hexToRgb(hex);const[h,s,l]=rgbToHsl(r,g,b);return hslToHex((h+deg+360)%360,s,l);}

  function applyTweaks(t) {
    const b2 = shiftHue(t.blob, -20);
    document.documentElement.style.setProperty('--blob1', t.blob);
    document.documentElement.style.setProperty('--blob2', b2);
    document.documentElement.style.setProperty('--accent', b2);
    document.documentElement.style.setProperty('--bg', t.bg);
    const isLight = !t.bg.startsWith('#0');
    document.documentElement.style.setProperty('--bg2', isLight ? shiftHue(t.bg, 0).replace(/#(..)(..)(..)/, (_,r,g,bb)=>'#'+[parseInt(r,16)-14,parseInt(g,16)-14,parseInt(bb,16)-14].map(v=>Math.max(0,v).toString(16).padStart(2,'0')).join('')) : '#111115');
    document.documentElement.style.setProperty('--ink', isLight ? '#171410' : '#e8e4dc');
    document.documentElement.style.setProperty('--muted', isLight ? '#7a7265' : '#7a7570');
    document.documentElement.style.setProperty('--border', isLight ? 'rgba(23,20,16,0.1)' : 'rgba(255,255,255,0.08)');
  }
  applyTweaks(tweaks);

  document.getElementById('tw-blob').addEventListener('input', e => { tweaks.blob=e.target.value; applyTweaks(tweaks); window.parent.postMessage({type:'__edit_mode_set_keys',edits:tweaks},'*'); });
  document.getElementById('tw-bg').addEventListener('change', e => { tweaks.bg=e.target.value; applyTweaks(tweaks); window.parent.postMessage({type:'__edit_mode_set_keys',edits:tweaks},'*'); });

  window.addEventListener('message', e => {
    if (e.data?.type === '__activate_edit_mode') document.getElementById('tweaks-panel').classList.add('active');
    if (e.data?.type === '__deactivate_edit_mode') document.getElementById('tweaks-panel').classList.remove('active');
  });
  window.parent.postMessage({type:'__edit_mode_available'},'*');
</script>
