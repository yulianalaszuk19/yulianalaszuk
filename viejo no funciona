<style>
  :root {
    --bg:    #ece5d8;
    --bg2:   #e2d9c9;
    --ink:   #171410;
    --muted: #7a7265;
    --border: rgba(23,20,16,0.1);
    --blob1: #f97316;
    --blob2: #d93a0e;
    --accent: #d93a0e;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--ink); font-family: 'DM Sans', sans-serif; font-weight: 300; line-height: 1.7; overflow-x: hidden; }

  /* ── NAV ── */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; padding: 1.2rem 3rem; background: rgba(236,229,216,0.9); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); }
  nav .logo { font-weight: 700; font-size: 0.85rem; letter-spacing: 0.05em; text-decoration: none; color: var(--ink); }
  nav ul { display: flex; gap: 2rem; list-style: none; }
  nav ul a { color: var(--muted); text-decoration: none; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.25s; }
  nav ul a:hover { color: var(--accent); }

  /* ── HERO ── */
  .hero { min-height: 100vh; padding: 7rem 3rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; top: 50%; left: 22%; transform: translate(-50%,-50%); width: 55vw; height: 55vw; background: radial-gradient(circle at 40% 50%, var(--blob1) 0%, var(--blob2) 45%, transparent 70%); filter: blur(80px); opacity: 0.5; pointer-events: none; animation: blobPulse 6s ease-in-out infinite; }
  @keyframes blobPulse { 0%,100% { transform: translate(-50%,-50%) scale(1); opacity: 0.5; } 50% { transform: translate(-50%,-50%) scale(1.08); opacity: 0.62; } }

  .hero-left { position: relative; z-index: 1; }
  .hero-eyebrow { display: inline-block; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.5rem; opacity: 0; animation: fadeUp 0.7s ease 0.2s forwards; }
  .hero-name { font-weight: 900; font-size: clamp(4rem, 9vw, 9rem); line-height: 0.88; letter-spacing: -0.03em; opacity: 0; animation: fadeUp 0.8s ease 0.35s forwards; }
  .hero-name span { display: block; }
  .hero-pills { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 2.5rem; opacity: 0; animation: fadeUp 0.7s ease 0.55s forwards; }
  .hero-pill { border: 1.5px solid rgba(23,20,16,0.28); border-radius: 100px; padding: 0.45rem 1.1rem; font-size: 0.78rem; color: var(--ink); }
  .hero-desc { margin-top: 2rem; font-size: 0.95rem; color: var(--muted); max-width: 420px; line-height: 1.85; opacity: 0; animation: fadeUp 0.7s ease 0.7s forwards; }
  .hero-cta { margin-top: 2.5rem; opacity: 0; animation: fadeUp 0.7s ease 0.85s forwards; }
  .btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--ink); color: var(--bg); text-decoration: none; font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.8rem 1.8rem; border-radius: 100px; transition: background 0.3s, transform 0.2s; }
  .btn-primary:hover { background: var(--accent); transform: translateY(-2px); }

  .hero-right { position: relative; z-index: 1; display: flex; justify-content: center; align-items: center; opacity: 0; animation: fadeUp 1s ease 0.5s forwards; }
  .photo-wrap { position: relative; width: clamp(260px, 30vw, 420px); aspect-ratio: 3/4; }
  .photo-wrap::before { content: ''; position: absolute; inset: -14px; border-radius: 200px 200px 160px 160px; background: linear-gradient(135deg, var(--blob1) 0%, var(--blob2) 100%); opacity: 0.22; z-index: 0; }
  .photo-wrap img { position: relative; z-index: 1; width: 100%; height: 100%; object-fit: cover; object-position: center top; border-radius: 180px 180px 140px 140px; display: block; }

  /* ── SHARED ── */
  section { padding: 6rem 3rem; }
  .section-header { display: flex; align-items: baseline; gap: 1.2rem; margin-bottom: 3.5rem; }
  .section-num { font-size: 0.65rem; letter-spacing: 0.2em; color: var(--muted); flex-shrink: 0; }
  .section-title { font-weight: 700; font-size: clamp(1.8rem, 3.5vw, 2.8rem); letter-spacing: -0.02em; }
  .section-line { flex: 1; height: 1px; background: var(--border); }

  /* ── SERVICIOS ── */
  #servicios { background: var(--ink); }
  #servicios .section-title { color: var(--bg); }
  #servicios .section-num { color: rgba(236,229,216,0.35); }
  #servicios .section-line { background: rgba(236,229,216,0.12); }
  .servicios-intro { color: rgba(236,229,216,0.55); font-size: 0.95rem; max-width: 580px; margin-bottom: 3rem; line-height: 1.85; }
  .servicios-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(236,229,216,0.1); }
  .servicio-card { background: var(--ink); padding: 2.5rem 2rem; transition: background 0.3s; cursor: default; }
  .servicio-card:hover { background: #1f1e1a; }
  .servicio-icon { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--blob1), var(--blob2)); display: flex; align-items: center; justify-content: center; margin-bottom: 1.4rem; flex-shrink: 0; }
  .servicio-icon svg { width: 18px; height: 18px; stroke: white; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .servicio-card h3 { font-weight: 700; font-size: 0.95rem; color: var(--bg); margin-bottom: 0.6rem; }
  .servicio-card p { font-size: 0.82rem; color: rgba(236,229,216,0.45); line-height: 1.75; }

  /* ── PERFIL ── */
  #perfil { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .perfil-grid { display: grid; grid-template-columns: 1fr 1.8fr; gap: 5rem; align-items: start; }
  .perfil-aside blockquote { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.7rem; font-weight: 300; line-height: 1.4; color: var(--ink); border-left: 3px solid var(--accent); padding-left: 1.2rem; margin-bottom: 2rem; }
  .linkedin-link { display: inline-flex; align-items: center; gap: 0.6rem; background: var(--ink); color: var(--bg); text-decoration: none; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.65rem 1.4rem; border-radius: 100px; transition: background 0.3s; }
  .linkedin-link:hover { background: var(--accent); }
  .perfil-text p { font-size: 0.98rem; color: #5c5650; line-height: 1.9; margin-bottom: 1rem; }
  .perfil-text p:last-child { margin-bottom: 0; }

  /* ── TIMELINE ── */
  #experiencia { border-top: 1px solid var(--border); }
  .timeline { display: flex; flex-direction: column; }
  .timeline-item { display: grid; grid-template-columns: 200px 40px 1fr; padding-bottom: 4rem; }
  .timeline-item:last-child { padding-bottom: 0; }
  .tl-date { padding-top: 0.15rem; text-align: right; }
  .tl-date .period { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); display: block; margin-bottom: 0.2rem; font-weight: 500; }
  .tl-date .org { font-size: 0.76rem; color: var(--muted); line-height: 1.45; }
  .tl-spine { display: flex; flex-direction: column; align-items: center; padding-top: 0.3rem; }
  .tl-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
  .tl-line { flex: 1; width: 1px; background: var(--border); margin-top: 6px; }
  .timeline-item:last-child .tl-line { display: none; }
  .tl-body { padding-top: 0; }
  .tl-role { font-weight: 700; font-size: 1.15rem; letter-spacing: -0.01em; margin-bottom: 0.7rem; line-height: 1.3; }
  .tl-role em { font-weight: 300; font-style: normal; color: var(--muted); display: block; font-size: 0.88em; margin-top: 0.15rem; }
  .tl-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.8; margin-bottom: 0.5rem; }
  .tl-desc li { margin-left: 1rem; margin-bottom: 0.3rem; }
  .tl-badge { display: inline-block; margin-top: 0.9rem; background: var(--accent); color: #fff; font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.35rem 1rem; border-radius: 100px; font-weight: 500; }

  /* ── GALLERY ── */
  .tl-gallery-wrap { position: relative; margin-top: 1.4rem; padding: 0 24px; }
  .tl-gallery { display: flex; gap: 0.75rem; overflow-x: auto; padding-bottom: 0.5rem; scroll-behavior: smooth; scrollbar-width: none; }
  .tl-gallery::-webkit-scrollbar { display: none; }
  .tl-gallery img { height: 200px; width: auto; min-width: 140px; border-radius: 12px; object-fit: cover; flex-shrink: 0; cursor: pointer; transition: transform 0.25s, box-shadow 0.25s; }
  .tl-gallery img:hover { transform: scale(1.03); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }
  .gallery-btn { position: absolute; top: 50%; transform: translateY(-60%); width: 34px; height: 34px; border-radius: 50%; background: var(--ink); color: var(--bg); border: none; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; z-index: 2; transition: background 0.2s; }
  .gallery-btn:hover { background: var(--accent); }
  .gallery-btn.prev { left: 0; }
  .gallery-btn.next { right: 0; }

  /* ── LIGHTBOX ── */
  .lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 1000; display: none; align-items: center; justify-content: center; padding: 2rem; }
  .lightbox.open { display: flex; }
  .lightbox img { max-width: 90vw; max-height: 88vh; object-fit: contain; border-radius: 8px; }
  .lightbox-close { position: absolute; top: 1.5rem; right: 2rem; color: white; font-size: 2.2rem; cursor: pointer; opacity: 0.6; transition: opacity 0.2s; line-height: 1; }
  .lightbox-close:hover { opacity: 1; }

  /* ── PRENSA ── */
  #prensa { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .media-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .media-card { background: var(--bg); border-radius: 16px; overflow: hidden; border: 1px solid var(--border); transition: transform 0.25s, box-shadow 0.25s; }
  .media-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); }
  .video-wrap { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; }
  .video-wrap iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }
  .media-card-body { padding: 1.5rem; }
  .media-label { font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); font-weight: 500; margin-bottom: 0.5rem; }
  .media-card h3 { font-weight: 700; font-size: 1rem; line-height: 1.4; margin-bottom: 0.6rem; }
  .media-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.7; margin-bottom: 1rem; }
  .media-link { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.75rem; font-weight: 500; color: var(--accent); text-decoration: none; }
  .media-link:hover { text-decoration: underline; }
  .news-thumb { height: 190px; overflow: hidden; }
  .news-thumb img { width: 100%; height: 100%; object-fit: cover; }

  /* ── FORMACION ── */
  #formacion { border-top: 1px solid var(--border); }
  .edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
  .edu-card { background: var(--bg2); padding: 2rem; border-radius: 16px; border: 1px solid var(--border); transition: transform 0.25s, box-shadow 0.25s; }
  .edu-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.07); }
  .edu-card .year { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.8rem; font-weight: 500; }
  .edu-card h3 { font-weight: 700; font-size: 1rem; line-height: 1.35; margin-bottom: 0.4rem; }
  .edu-card .inst { font-size: 0.78rem; color: var(--muted); }

  /* ── CAPACITACIONES ── */
  #capacitaciones { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .cap-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.2rem; }
  .cap-item { padding: 1.4rem 1.4rem 1.4rem 1.2rem; border-left: 3px solid var(--blob1); background: var(--bg); border-radius: 0 12px 12px 0; }
  .cap-item .cap-year { font-size: 0.63rem; color: var(--accent); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 0.3rem; font-weight: 500; }
  .cap-item .cap-title { font-size: 0.88rem; font-weight: 500; line-height: 1.4; margin-bottom: 0.2rem; }
  .cap-item .cap-inst { font-size: 0.74rem; color: var(--muted); }

  /* ── HERRAMIENTAS ── */
  #herramientas { border-top: 1px solid var(--border); }
  .tools-grid { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .tool-tag { border: 1.5px solid var(--border); border-radius: 100px; color: var(--ink); font-size: 0.8rem; padding: 0.5rem 1.1rem; transition: border-color 0.25s, background 0.25s; cursor: default; }
  .tool-tag:hover { border-color: var(--accent); background: rgba(217,58,14,0.05); }

  /* ── IDIOMAS ── */
  #idiomas { background: var(--bg2); border-top: 1px solid var(--border); }
  .lang-grid { display: flex; gap: 4rem; flex-wrap: wrap; }
  .lang-item { flex: 1; min-width: 160px; }
  .lang-name { font-weight: 700; font-size: 1.5rem; letter-spacing: -0.02em; margin-bottom: 0.3rem; }
  .lang-level { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.9rem; font-weight: 500; }
  .lang-bar { height: 3px; background: var(--border); border-radius: 10px; overflow: hidden; }
  .lang-fill { height: 100%; background: linear-gradient(to right, var(--blob1), var(--blob2)); border-radius: 10px; }

  /* ── FOOTER ── */
  footer { padding: 3.5rem 3rem; border-top: 1px solid var(--border); background: var(--ink); color: var(--bg); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  footer .f-name { font-weight: 900; font-size: 1.5rem; letter-spacing: -0.02em; }
  footer .f-right { text-align: right; font-size: 0.72rem; color: rgba(236,229,216,0.45); line-height: 2; }
  footer a { color: var(--blob1); text-decoration: none; }
  footer a:hover { text-decoration: underline; }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: none; } }
  .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.65s ease, transform 0.65s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  /* ── TWEAKS ── */
  #tweaks-panel { display: none; position: fixed; bottom: 1.5rem; right: 1.5rem; background: var(--bg); border: 1px solid var(--border); box-shadow: 0 8px 32px rgba(0,0,0,0.12); padding: 1.4rem; z-index: 999; width: 230px; border-radius: 16px; }
  #tweaks-panel.active { display: block; }
  #tweaks-panel h4 { font-weight: 700; font-size: 0.85rem; margin-bottom: 1.1rem; }
  .tweak-row { margin-bottom: 1rem; }
  .tweak-row label { display: block; color: var(--muted); font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.35rem; }
  .tweak-row select, .tweak-row input[type=color] { background: var(--bg2); border: 1px solid var(--border); color: var(--ink); padding: 0.4rem 0.6rem; width: 100%; font-size: 0.8rem; border-radius: 8px; cursor: pointer; }
  .tweak-row input[type=color] { height: 36px; padding: 2px; }

  @media (max-width: 900px) {
    .servicios-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; } nav ul { display: none; }
    .hero { grid-template-columns: 1fr; padding: 6rem 1.5rem 3rem; gap: 2.5rem; }
    .hero-right { order: -1; }
    section { padding: 4rem 1.5rem; }
    .perfil-grid { grid-template-columns: 1fr; gap: 2rem; }
    .timeline-item { grid-template-columns: 1fr; }
    .tl-spine { display: none; }
    .tl-date { text-align: left; margin-bottom: 0.5rem; }
    .media-grid { grid-template-columns: 1fr; }
    .servicios-grid { grid-template-columns: 1fr; }
    footer { padding: 2.5rem 1.5rem; }
  }
</style>
</head>
